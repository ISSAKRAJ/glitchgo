# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini API Configurations
GEMINI_API_KEY=your-gemini-api-key
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Groq API Configurations
GROQ_API_KEY=your-groq-api-key

# OpenRouter API Configurations
OPENROUTER_API_KEY=your-openrouter-api-key

# DeepSeek API Configurations (Optional direct key)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Port configuration
PORT=5000

# AES-256-GCM Encryption Key (Required, must be a 64-char hex string representing 32 bytes)
# Run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate one
ENCRYPTION_KEY=your-generated-64-character-hex-string

# UPI ID & Payments
NEXT_PUBLIC_UPI_ID=your-upi-id
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=your-email@example.com

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
